{
  "hooks": {
    "AfterTool": [
      {
        "hooks": [
          {
            "async": true,
            "command": "ari hook clew --output json",
            "env": {
              "KNOSSOS_CHANNEL": "gemini"
            },
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "replace|write_file|run_shell_command"
      },
      {
        "hooks": [
          {
            "async": true,
            "command": "ari hook suggest --output json",
            "env": {
              "KNOSSOS_CHANNEL": "gemini"
            },
            "timeout": 5,
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": "ari hook budget --output json",
            "env": {
              "KNOSSOS_CHANNEL": "gemini"
            },
            "timeout": 3,
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "async": true,
            "command": "ari hook driftdetect --output json",
            "env": {
              "KNOSSOS_CHANNEL": "gemini"
            },
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "BeforeTool": [
      {
        "hooks": [
          {
            "command": "ari hook writeguard --output json",
            "env": {
              "KNOSSOS_CHANNEL": "gemini"
            },
            "timeout": 3,
            "type": "command"
          }
        ],
        "matcher": "replace|write_file"
      },
      {
        "hooks": [
          {
            "command": "ari hook validate --output json",
            "env": {
              "KNOSSOS_CHANNEL": "gemini"
            },
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "run_shell_command"
      },
      {
        "hooks": [
          {
            "command": "ari hook git-conventions --output json",
            "env": {
              "KNOSSOS_CHANNEL": "gemini"
            },
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "run_shell_command"
      },
      {
        "hooks": [
          {
            "command": "ari hook attribution-guard --output json",
            "env": {
              "KNOSSOS_CHANNEL": "gemini"
            },
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "run_shell_command"
      }
    ],
    "PreCompress": [
      {
        "hooks": [
          {
            "command": "ari hook precompact --output json",
            "env": {
              "KNOSSOS_CHANNEL": "gemini"
            },
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "command": "ari hook sessionend --output json",
            "env": {
              "KNOSSOS_CHANNEL": "gemini"
            },
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "ari hook context --output json",
            "env": {
              "KNOSSOS_CHANNEL": "gemini"
            },
            "timeout": 10,
            "type": "command"
          }
        ]
      }
    ]
  }
}