# _globals.just
# Project constants and paths
# Loaded first - other modules reference these values

# === Application ===
APP := "myapp"
VERSION := `git describe --tags --always 2>/dev/null || echo "dev"`

# === Tooling ===
# Adjust these for your project's toolchain
PY := "uv run python"
UV := "uv"
PYTEST := "uv run pytest"

# === Docker ===
DOCKER := "docker"
IMAGE := APP
REGISTRY := "ghcr.io/your-org"
TAG := VERSION

# === Paths ===
SRC := "src"
TESTS := "tests"
DOCS := "docs"

# === Environment ===
# Defaults that can be overridden by .env or shell
ENV := env_var_or_default("ENV", "development")
CI := env_var_or_default("CI", "false")
