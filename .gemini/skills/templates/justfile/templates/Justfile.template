# Justfile
# Project task runner - thin router only
#
# Usage: just <recipe>
# Help:  just --list

# === Settings ===
set dotenv-load := true
set export := true
set shell := ["bash", "-eu", "-o", "pipefail", "-c"]

# === Imports: Primitives (always load first) ===
import "just/_globals.just"
import "just/_helpers.just"
import "just/_env.just"

# === Imports: Domain Modules ===
# Uncomment as needed for your project

import "just/dev.just"
import "just/fmt.just"
import "just/test.just"
# import "just/docker.just"
# import "just/db.just"
# import "just/deploy.just"
# import "just/ci.just"

# === Default Recipe ===
# Shows help when running `just` with no arguments
default:
    @just --list
