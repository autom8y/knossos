{
  "mcpServers": {
    "github": {
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "command": "npx",
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      }
    },
    "go-semantic": {
      "command": "go-semantic-mcp"
    },
    "terraform": {
      "args": [
        "-y",
        "@modelcontextprotocol/server-terraform"
      ],
      "command": "npx"
    }
  }
}