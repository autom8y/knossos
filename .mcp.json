{
  "mcpServers": {
    "duckdb": {
      "args": [
        "mcp-server-motherduck",
        "--db-path",
        ":memory:",
        "--read-write"
      ],
      "command": "uvx"
    },
    "go-semantic": {
      "command": "go-semantic-mcp"
    },
    "terraform": {
      "args": [
        "-y",
        "@modelcontextprotocol/server-terraform"
      ],
      "command": "npx"
    }
  }
}