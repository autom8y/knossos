#!/usr/bin/env bash
#
# roster-sync - Roster-Native Ecosystem Synchronization
#
# Replaces CEM (Claude Ecosystem Manager) with roster-native functionality.
# Manages ecosystem file synchronization between roster and satellite projects.
#
# Part of: CEM Migration (TDD-cem-replacement)
#
# Usage:
#   roster-sync <command> [options]
#
# Commands:
#   init      Initialize project with ecosystem files
#   sync      Pull updates from roster
#   validate  Validate manifest integrity
#   repair    Rebuild manifest from state
#   status    Show sync status
#   diff      Show differences with roster
#
# Global Options:
#   --force       Overwrite local changes
#   --dry-run     Preview without changes
#   --refresh     Also refresh active team
#   --prune       Remove orphaned files
#   --auto-refresh  Auto-refresh if team updates
#   --debug       Enable debug output
#   -h, --help    Show help
#   -v, --version Show version

set -euo pipefail

# ============================================================================
# Constants
# ============================================================================

readonly ROSTER_HOME="${ROSTER_HOME:-$HOME/Code/roster}"
readonly ROSTER_SYNC_VERSION="1.0.0"
readonly ROSTER_SYNC_DEBUG="${ROSTER_SYNC_DEBUG:-0}"

# Source library modules in dependency order
readonly SYNC_LIB="$ROSTER_HOME/lib/sync"

# ============================================================================
# Logging
# ============================================================================

# Colors for output (if terminal supports it)
if [[ -t 1 ]]; then
    readonly RED='\033[0;31m'
    readonly GREEN='\033[0;32m'
    readonly YELLOW='\033[1;33m'
    readonly BLUE='\033[0;34m'
    readonly NC='\033[0m' # No Color
else
    readonly RED=''
    readonly GREEN=''
    readonly YELLOW=''
    readonly BLUE=''
    readonly NC=''
fi

log() {
    echo -e "${BLUE}[roster-sync]${NC} $*"
}

log_error() {
    echo -e "${RED}[roster-sync] Error:${NC} $*" >&2
}

log_warning() {
    echo -e "${YELLOW}[roster-sync] Warning:${NC} $*" >&2
}

log_success() {
    echo -e "${GREEN}[roster-sync]${NC} $*"
}

log_debug() {
    if [[ "${ROSTER_SYNC_DEBUG:-0}" == "1" || "${DEBUG:-}" == "1" ]]; then
        echo -e "[roster-sync DEBUG] $*" >&2
    fi
}

# ============================================================================
# Dependency Check
# ============================================================================

check_dependencies() {
    # Check jq
    if ! command -v jq &>/dev/null; then
        log_error "jq is required but not installed"
        log_error "Install with: brew install jq (macOS) or apt install jq (Linux)"
        exit 1
    fi

    # Check jq version (1.6+)
    local jq_version
    jq_version=$(jq --version 2>/dev/null | sed 's/jq-//' || echo "0")
    log_debug "jq version: $jq_version"
}

# ============================================================================
# Library Loading
# ============================================================================

load_sync_library() {
    if [[ ! -d "$SYNC_LIB" ]]; then
        log_error "Sync library not found: $SYNC_LIB"
        log_error "Ensure ROSTER_HOME is set correctly: $ROSTER_HOME"
        exit 1
    fi

    # Source in dependency order
    # shellcheck source=lib/sync/sync-config.sh
    source "$SYNC_LIB/sync-config.sh"

    # shellcheck source=lib/sync/sync-checksum.sh
    source "$SYNC_LIB/sync-checksum.sh"

    # shellcheck source=lib/sync/sync-manifest.sh
    source "$SYNC_LIB/sync-manifest.sh"

    # shellcheck source=lib/sync/sync-core.sh
    source "$SYNC_LIB/sync-core.sh"

    # shellcheck source=lib/sync/merge/merge-settings.sh
    source "$SYNC_LIB/merge/merge-settings.sh"

    # shellcheck source=lib/sync/merge/merge-docs.sh
    source "$SYNC_LIB/merge/merge-docs.sh"

    # shellcheck source=lib/sync/merge/dispatcher.sh
    source "$SYNC_LIB/merge/dispatcher.sh"

    log_debug "Sync library loaded from: $SYNC_LIB"
}

# ============================================================================
# Flag Parsing
# ============================================================================

# Global flags
FLAG_FORCE=0
FLAG_DRY_RUN=0
FLAG_REFRESH=0
FLAG_PRUNE=0
FLAG_AUTO_REFRESH=0
FLAG_VERBOSE=0
FLAG_TEAM=0

parse_global_flags() {
    local args=()

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --force|-f)
                FLAG_FORCE=1
                shift
                ;;
            --dry-run|-n)
                FLAG_DRY_RUN=1
                shift
                ;;
            --refresh|-r)
                FLAG_REFRESH=1
                shift
                ;;
            --prune|-p)
                FLAG_PRUNE=1
                shift
                ;;
            --auto-refresh)
                FLAG_AUTO_REFRESH=1
                shift
                ;;
            --verbose|-V)
                FLAG_VERBOSE=1
                shift
                ;;
            --team=*)
                # For init command: pass through with value
                FLAG_TEAM=1
                args+=("$1")
                shift
                ;;
            --team|-t)
                # Check if next arg looks like a value (for init) or is a flag/command
                if [[ $# -gt 1 && "${2:-}" != -* && "${2:-}" != "init" && "${2:-}" != "sync" && "${2:-}" != "validate" && "${2:-}" != "repair" && "${2:-}" != "status" && "${2:-}" != "diff" ]]; then
                    # Has a value - pass through for init command
                    args+=("$1" "$2")
                    shift 2
                else
                    # Boolean flag for validate command
                    FLAG_TEAM=1
                    shift
                fi
                ;;
            --debug|-d)
                export ROSTER_SYNC_DEBUG=1
                shift
                ;;
            -*)
                # Unknown flag, pass through
                args+=("$1")
                shift
                ;;
            *)
                # Positional argument
                args+=("$1")
                shift
                ;;
        esac
    done

    # Return remaining args
    REMAINING_ARGS=("${args[@]}")
}

