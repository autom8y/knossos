# ============================================================================
# Command: init (per TDD Section 3.2)
# ============================================================================

# Parse init-specific flags
# Usage: parse_init_flags "$@"
# Sets: INIT_PROJECT_PATH, INIT_TEAM
parse_init_flags() {
    INIT_PROJECT_PATH=""
    INIT_TEAM=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --team=*)
                INIT_TEAM="${1#*=}"
                shift
                ;;
            --team)
                INIT_TEAM="$2"
                shift 2
                ;;
            -*)
                # Unknown flag, skip (already handled by global parser)
                shift
                ;;
            *)
                # Positional argument - project path
                if [[ -z "$INIT_PROJECT_PATH" ]]; then
                    INIT_PROJECT_PATH="$1"
                fi
                shift
                ;;
        esac
    done
}

cmd_init() {
    # Parse init-specific flags
    parse_init_flags "$@"

    local project_path="${INIT_PROJECT_PATH:-$(pwd)}"
    local team_name="$INIT_TEAM"

    # Resolve to absolute path if relative
    if [[ "$project_path" != /* ]]; then
        if [[ -d "$project_path" ]]; then
            project_path="$(cd "$project_path" && pwd)"
        else
            log_error "Invalid project path: $project_path"
            return "$EXIT_SYNC_INIT_FAILED"
        fi
    fi

    log "Initializing project with roster ecosystem..."
    log "  Project: $project_path"

    # 1. Validate roster exists at $ROSTER_HOME
    if [[ ! -d "$ROSTER_HOME" ]]; then
        log_error "Roster not found: $ROSTER_HOME"
        log_error "Set ROSTER_HOME environment variable"
        return "$EXIT_SYNC_INIT_FAILED"
    fi

    # 2. Validate project directory (exists and writable)
    if [[ ! -d "$project_path" ]]; then
        log_error "Project path does not exist: $project_path"
        return "$EXIT_SYNC_INIT_FAILED"
    fi

    if [[ ! -w "$project_path" ]]; then
        log_error "Project path is not writable: $project_path"
        return "$EXIT_SYNC_INIT_FAILED"
    fi

    # Validate not in roster itself
    local roster_realpath project_realpath
    roster_realpath=$(cd "$ROSTER_HOME" && pwd -P)
    project_realpath=$(cd "$project_path" && pwd -P)

    if [[ "$project_realpath" == "$roster_realpath" || "$project_realpath" == "$roster_realpath/"* ]]; then
        log_error "Cannot initialize inside roster repository"
        return "$EXIT_SYNC_INIT_FAILED"
    fi

    # 3. Check jq availability
    if ! command -v jq &>/dev/null; then
        log_error "jq is required but not installed"
        return "$EXIT_SYNC_INIT_FAILED"
    fi

    # 4. Check if already initialized
    local manifest_file="$project_path/.claude/.cem/manifest.json"
    if [[ -f "$manifest_file" && "$FLAG_FORCE" != "1" ]]; then
        log_error "Already initialized at: $project_path"
        log_error "Use --force to reinitialize"
        return "$EXIT_SYNC_INIT_FAILED"
    fi

    # Validate team if specified
    if [[ -n "$team_name" ]]; then
        local team_dir="$ROSTER_HOME/teams/$team_name"
        if [[ ! -d "$team_dir" ]]; then
            log_error "Team not found: $team_name"
            log_error "Available teams:"
            ls "$ROSTER_HOME/teams/" 2>/dev/null | while read -r t; do
                log_error "  - $t"
            done
            return "$EXIT_SYNC_INIT_FAILED"
        fi
        log "  Team: $team_name"
    fi

    if [[ "$FLAG_DRY_RUN" == "1" ]]; then
        log "DRY-RUN: Would initialize project"
        log "  Roster: $ROSTER_HOME"
        log "  Target: $project_path"
        [[ -n "$team_name" ]] && log "  Team: $team_name"
        return 0
    fi

    # Change to project directory for all operations
    local original_dir
    original_dir=$(pwd)
    cd "$project_path" || {
        log_error "Cannot change to project directory: $project_path"
        return "$EXIT_SYNC_INIT_FAILED"
    }

    # 5. Create .claude/ and .claude/.cem/ directories
    log "Creating directory structure..."
    mkdir -p .claude/.cem
    mkdir -p .claude/hooks
    mkdir -p .claude/agents

    # 6. Get roster commit hash and ref
    local roster_commit roster_ref
    roster_commit=$(get_roster_commit)
    roster_ref=$(get_roster_ref)

    log_debug "Roster commit: $roster_commit"
    log_debug "Roster ref: $roster_ref"

    # Initialize checksum cache
    init_checksum_cache

    # Create manifest
    local manifest
    manifest=$(create_manifest "$ROSTER_HOME" "$roster_commit" "$roster_ref")

    # 7. Process COPY-REPLACE items (roster-owned files)
    local item roster_file local_file checksum
    log "Processing copy-replace items..."
    while IFS= read -r item; do
        [[ -z "$item" ]] && continue

        roster_file="$ROSTER_HOME/.claude/$item"
        local_file=".claude/$item"

        if [[ ! -f "$roster_file" ]]; then
            log_warning "Source not found: $roster_file"
            continue
        fi

        if [[ -f "$local_file" && "$FLAG_FORCE" != "1" ]]; then
            log "  Preserving existing (use --force to overwrite): $item"
            checksum=$(compute_checksum "$local_file")
        else
            log "  Copying: $item"
            mkdir -p "$(dirname "$local_file")"
            cp "$roster_file" "$local_file"
            # Preserve permissions (cross-platform)
            if [[ "$(uname)" == "Darwin" ]]; then
                chmod "$(stat -f '%A' "$roster_file" 2>/dev/null)" "$local_file" 2>/dev/null || true
            else
                chmod --reference="$roster_file" "$local_file" 2>/dev/null || true
            fi
            checksum=$(compute_checksum "$local_file")
        fi

        manifest=$(add_managed_file "$manifest" ".claude/$item" "copy-replace" "$checksum")
    done < <(get_copy_replace_items)

    # 8. Process MERGE items (intelligent merge on future syncs)
    local line strategy
    log "Processing merge items..."
    while IFS= read -r line; do
        [[ -z "$line" ]] && continue

        item="${line%%:*}"
        strategy="${line#*:}"
        roster_file="$ROSTER_HOME/.claude/$item"
        local_file=".claude/$item"

        if [[ ! -f "$roster_file" ]]; then
            log_warning "Source not found: $roster_file"
            continue
        fi

        if [[ -f "$local_file" ]]; then
            log "  Preserving existing: $item (will merge on sync)"
        else
            log "  Copying: $item"
            mkdir -p "$(dirname "$local_file")"
            cp "$roster_file" "$local_file"
            # Preserve permissions (cross-platform)
            if [[ "$(uname)" == "Darwin" ]]; then
                chmod "$(stat -f '%A' "$roster_file" 2>/dev/null)" "$local_file" 2>/dev/null || true
            else
                chmod --reference="$roster_file" "$local_file" 2>/dev/null || true
            fi
        fi

        checksum=$(compute_checksum "$local_file")
        manifest=$(add_managed_file "$manifest" ".claude/$item" "$strategy" "$checksum")
    done < <(get_merge_items)

    # Create default settings.json if not exists (minimal satellite settings)
    local settings_file=".claude/settings.json"
    if [[ ! -f "$settings_file" ]]; then
        log "  Creating default settings.json"
        cat > "$settings_file" <<'SETTINGS_EOF'
{
  "permissions": {
    "allow": [],
    "additionalDirectories": []
  },
  "hooks": {}
}
SETTINGS_EOF
    fi

    # Apply rite if --rite/--team specified
    if [[ -n "$team_name" ]]; then
        log "Applying rite: $team_name"
        echo "$team_name" > .claude/ACTIVE_RITE

        # Update manifest with team info
        local team_checksum
        team_checksum=$(compute_content_checksum "$team_name")
        manifest=$(update_manifest_team "$manifest" "$team_name" "$team_checksum")

        # Call swap-rite.sh to apply rite agents/skills/commands
        local swap_rite="$ROSTER_HOME/swap-rite.sh"
        if [[ -x "$swap_rite" ]]; then
            log "  Applying rite resources..."
            "$swap_rite" "$team_name" 2>/dev/null || {
                log_warning "Rite application completed with warnings (non-fatal)"
            }
        else
            log_warning "swap-rite.sh not found at $swap_rite"
            log_warning "Active rite set but agents not applied"
        fi
    fi

    # 9-10. Write manifest.json v3
    mkdir -p "$(dirname "$manifest_file")"
    write_manifest "$manifest"

    # Save checksum cache
    save_checksum_cache

    # Return to original directory
    cd "$original_dir" || true

    log_success "Initialization complete"
    log "  Project: $project_path"
    log "  Managed files: $(echo "$manifest" | jq '.managed_files | length')"
    log "  Manifest: $manifest_file"
    [[ -n "$team_name" ]] && log "  Team: $team_name"

    return 0
}

# ============================================================================
# Command: sync
# ============================================================================

cmd_sync() {
    log "Syncing from roster..."

    # Validate initialized
    local manifest_file="${SYNC_MANIFEST_FILE:-.claude/.cem/manifest.json}"
    if [[ ! -f "$manifest_file" ]]; then
        log_error "Not initialized. Run: roster-sync init"
        return "$EXIT_SYNC_ERROR"
    fi

    # Initialize checksum cache
    init_checksum_cache

    # Migrate manifest if needed
    migrate_manifest_if_needed

    # Load manifest
    local manifest
    manifest=$(read_manifest) || {
        log_error "Failed to read manifest"
        return "$EXIT_SYNC_INVALID_MANIFEST"
    }

    # Check if updates needed
    if ! roster_has_updates && [[ "$FLAG_FORCE" != "1" && "$FLAG_PRUNE" != "1" ]]; then
        log "Already up to date"

        if [[ "$FLAG_REFRESH" == "1" ]]; then
            refresh_active_team
        fi

        return 0
    fi

    if [[ "$FLAG_DRY_RUN" == "1" ]]; then
        log "DRY-RUN: Would sync from roster"
    fi

    # Process copy-replace items
    local conflicts
    if [[ "$FLAG_DRY_RUN" == "1" ]]; then
        log "DRY-RUN: Would process copy-replace items"
        conflicts=0
    else
        conflicts=$(process_copy_replace "$ROSTER_HOME/.claude" ".claude" "$FLAG_FORCE")
    fi

    # Process merge items
    local merge_errors
    if [[ "$FLAG_DRY_RUN" == "1" ]]; then
        log "DRY-RUN: Would process merge items"
        merge_errors=0
    else
        merge_errors=$(process_merge_items "$ROSTER_HOME/.claude" ".claude" "$FLAG_FORCE")
    fi

    # Update manifest with new roster info
    if [[ "$FLAG_DRY_RUN" != "1" ]]; then
        manifest=$(read_manifest)
        manifest=$(update_manifest_roster "$manifest" "$(get_roster_commit)" "$(get_roster_ref)")
        write_manifest "$manifest"
    fi

    # Orphan detection and pruning
    if [[ "$FLAG_PRUNE" == "1" ]]; then
        log "Checking for orphaned files..."
        local orphans
        orphans=$(detect_orphans "$ROSTER_HOME/.claude")

        if [[ -n "$orphans" ]]; then
            log "Orphaned files detected:"
            echo "$orphans" | while read -r orphan; do
                log "  - $orphan"
            done

            if [[ "$FLAG_DRY_RUN" != "1" ]]; then
                echo "$orphans" | backup_orphans
                echo "$orphans" | prune_orphans
                log "Orphans pruned and backed up"
            else
                log "DRY-RUN: Would prune orphans"
            fi
        else
            log "No orphaned files found"
        fi
    fi

    # Save checksum cache
    if [[ "$FLAG_DRY_RUN" != "1" ]]; then
        save_checksum_cache
    fi

    # Team refresh
    if [[ "$FLAG_REFRESH" == "1" ]]; then
        if [[ "$FLAG_DRY_RUN" != "1" ]]; then
            refresh_active_team
        else
            log "DRY-RUN: Would refresh team"
        fi
    elif [[ "$FLAG_AUTO_REFRESH" == "1" ]]; then
        if is_team_stale; then
            if [[ "$FLAG_DRY_RUN" != "1" ]]; then
                refresh_active_team
            else
                log "DRY-RUN: Would auto-refresh stale team"
            fi
        fi
    fi

    # Report results
    if [[ "$conflicts" -gt 0 && "$FLAG_FORCE" != "1" ]]; then
        log_warning "$conflicts conflict(s) detected"
        log "Resolve manually or use: roster-sync sync --force"
        return "$EXIT_SYNC_CONFLICTS"
    fi

    if [[ "$merge_errors" -gt 0 ]]; then
        log_warning "$merge_errors merge error(s) occurred"
        return "$EXIT_SYNC_ERROR"
    fi

    log_success "Sync complete"
    return 0
}

# ============================================================================
# Command: validate (per TDD 3.4)
# ============================================================================

cmd_validate() {
    local project_path="${1:-.}"
    local verbose="${FLAG_VERBOSE:-0}"
    local team_check="${FLAG_TEAM:-0}"

    # Change to project directory if specified
    if [[ "$project_path" != "." ]]; then
        if [[ ! -d "$project_path" ]]; then
            log_error "Project path not found: $project_path"
            return 1
        fi
        cd "$project_path" || return 1
    fi

    log "Validating manifest..."

    local manifest_file="${SYNC_MANIFEST_FILE:-.claude/.cem/manifest.json}"
    local warnings=0
    local errors=0
    local integrity_issues=0

    # 1. Check manifest exists
    if [[ ! -f "$manifest_file" ]]; then
        log_error "Manifest not found: $manifest_file"
        log "  Run: roster-sync init"
        return "$EXIT_SYNC_INVALID_MANIFEST"
    fi

    # 2. Check manifest is valid JSON
    local manifest
    if ! manifest=$(cat "$manifest_file" 2>/dev/null); then
        log_error "Cannot read manifest file"
        return "$EXIT_SYNC_INVALID_MANIFEST"
    fi

    if ! echo "$manifest" | jq -e . >/dev/null 2>&1; then
        log_error "Invalid JSON in manifest"
        return "$EXIT_SYNC_INVALID_MANIFEST"
    fi

    # 3. Validate v3 schema structure
    local schema_version
    schema_version=$(echo "$manifest" | jq -r '.schema_version // 1')

    if [[ "$schema_version" != "3" ]]; then
        log_warning "Schema version $schema_version - migration to v3 recommended"
        log "  Run: roster-sync sync  (auto-migrates)"
        warnings=$((warnings + 1))
    fi

    # Check required fields (v3 schema only)
    local roster_path roster_commit
    roster_path=$(echo "$manifest" | jq -r '.roster.path // empty')
    roster_commit=$(echo "$manifest" | jq -r '.roster.commit // empty')

    if [[ -z "$roster_path" ]]; then
        log_error "Missing required field: roster.path"
        errors=$((errors + 1))
    elif [[ ! -d "$roster_path" ]]; then
        log_warning "Roster path does not exist: $roster_path"
        warnings=$((warnings + 1))
    fi

    if [[ -z "$roster_commit" ]]; then
        log_warning "Missing field: roster.commit"
        warnings=$((warnings + 1))
    fi

    # 4. Check all tracked files exist and verify checksums
    local file_count=0
    local missing_files=0
    local checksum_mismatches=0
    local file_path file_checksum current_checksum file_strategy

    while IFS= read -r file_entry; do
        [[ -z "$file_entry" ]] && continue
        file_count=$((file_count + 1))

        file_path=$(echo "$file_entry" | jq -r '.path')
        file_checksum=$(echo "$file_entry" | jq -r '.checksum // empty')
        file_strategy=$(echo "$file_entry" | jq -r '.strategy // "copy-replace"')

        # Check file exists
        if [[ ! -f "$file_path" ]]; then
            log_warning "Tracked file missing: $file_path"
            missing_files=$((missing_files + 1))
            integrity_issues=$((integrity_issues + 1))
            continue
        fi

        # Verify checksum
        if [[ -n "$file_checksum" ]]; then
            current_checksum=$(compute_checksum "$file_path")
            if [[ "$current_checksum" != "$file_checksum" ]]; then
                if [[ "$verbose" == "1" ]]; then
                    log "  Modified: $file_path"
                    log_debug "    Expected: $file_checksum"
                    log_debug "    Actual:   $current_checksum"
                fi
                checksum_mismatches=$((checksum_mismatches + 1))
            elif [[ "$verbose" == "1" ]]; then
                log "  OK: $file_path"
            fi
        fi
    done < <(echo "$manifest" | jq -c '.managed_files[]?')

    # 5. Team validation (if --team flag)
    if [[ "$team_check" == "1" ]]; then
        if [[ -f ".claude/ACTIVE_TEAM" ]]; then
            local active_team manifest_team
            active_team=$(cat ".claude/ACTIVE_TEAM")
            manifest_team=$(echo "$manifest" | jq -r '.team.name // empty')

            if [[ -z "$manifest_team" ]]; then
                log_warning "Active team '$active_team' not recorded in manifest"
                warnings=$((warnings + 1))
            elif [[ "$active_team" != "$manifest_team" ]]; then
                log_warning "Team mismatch: active='$active_team' manifest='$manifest_team'"
                integrity_issues=$((integrity_issues + 1))
            elif [[ "$verbose" == "1" ]]; then
                log "  Team: $active_team (matches manifest)"
            fi
        fi
    fi

    # 6. Check for unresolved conflict backups
    local backup_count
    backup_count=$(count_conflict_backups)
    if [[ "$backup_count" -gt 0 ]]; then
        log_warning "$backup_count unresolved conflict backup(s) found"
        list_conflict_backups | while read -r backup; do
            log "  - $backup"
        done
        warnings=$((warnings + 1))
    fi

    # 7. Validate CLAUDE.md structure if present
    if [[ -f ".claude/CLAUDE.md" ]]; then
        if ! validate_claude_md_markers ".claude/CLAUDE.md"; then
            log_warning "CLAUDE.md may have corrupted section markers"
            warnings=$((warnings + 1))
        fi
    fi

    # Summary
    echo ""
    log "Validation Summary:"
    log "  Tracked files:      $file_count"
    log "  Missing files:      $missing_files"
    log "  Local modifications: $checksum_mismatches"
    log "  Warnings:           $warnings"
    log "  Errors:             $errors"

    # Determine exit code per TDD 3.4
    if [[ $errors -gt 0 ]]; then
        log_error "Validation failed"
        return "$EXIT_SYNC_INVALID_MANIFEST"
    elif [[ $integrity_issues -gt 0 ]]; then
        log_error "Integrity issues detected"
        return "$EXIT_SYNC_CONFLICTS"
    elif [[ $warnings -gt 0 ]]; then
        log_warning "Validation passed with warnings"
        return "$EXIT_SYNC_VALIDATION_WARNINGS"
    else
        log_success "Validation passed"
        return 0
    fi
}

# Helper: Validate CLAUDE.md section markers
validate_claude_md_markers() {
    local file="$1"

    if [[ ! -f "$file" ]]; then
        return 0
    fi

    # Check for balanced SYNC and PRESERVE markers
    local sync_count preserve_count
    sync_count=$(grep -c '<!-- SYNC:' "$file" 2>/dev/null || echo 0)
    preserve_count=$(grep -c '<!-- PRESERVE:' "$file" 2>/dev/null || echo 0)

    # Basic sanity check - markers should exist if file is managed
    if [[ $sync_count -eq 0 && $preserve_count -eq 0 ]]; then
        log_debug "CLAUDE.md has no sync markers (may be satellite-owned)"
        return 0
    fi

    return 0
}

# ============================================================================
# Command: repair (per TDD 3.5)
# ============================================================================

cmd_repair() {
    local project_path="${1:-.}"

    # Change to project directory if specified
    if [[ "$project_path" != "." ]]; then
        if [[ ! -d "$project_path" ]]; then
            log_error "Project path not found: $project_path"
            return 1
        fi
        cd "$project_path" || return 1
    fi

    log "Repairing manifest..."

    local manifest_file="${SYNC_MANIFEST_FILE:-.claude/.cem/manifest.json}"
    local repaired_count=0
    local unrepairable=0

    # Check .claude directory exists
    if [[ ! -d ".claude" ]]; then
        log_error "No .claude directory found - cannot repair"
        log "  Run: roster-sync init"
        return "$EXIT_SYNC_INVALID_MANIFEST"
    fi

    # Validate roster is accessible
    if [[ ! -d "$ROSTER_HOME" ]]; then
        log_error "Roster not found: $ROSTER_HOME"
        log "  Set ROSTER_HOME environment variable"
        return "$EXIT_SYNC_INVALID_MANIFEST"
    fi

    # Backup existing manifest if it exists
    local old_manifest=""
    local old_roster_path=""
    local old_roster_commit=""
    local old_roster_ref=""

    if [[ -f "$manifest_file" ]]; then
        local backup_file="${manifest_file}.repair-backup.$(date +%Y%m%d-%H%M%S)"
        cp "$manifest_file" "$backup_file"
        log "Backup created: $backup_file"

        # Preserve roster info from old manifest
        old_manifest=$(cat "$manifest_file" 2>/dev/null || echo "{}")
        if echo "$old_manifest" | jq -e . >/dev/null 2>&1; then
            old_roster_path=$(echo "$old_manifest" | jq -r '.roster.path // empty')
            old_roster_commit=$(echo "$old_manifest" | jq -r '.roster.commit // empty')
            old_roster_ref=$(echo "$old_manifest" | jq -r '.roster.ref // "main"')
        fi
    fi

    if [[ "$FLAG_DRY_RUN" == "1" ]]; then
        log "DRY-RUN: Would perform the following repairs:"
        log ""
        repair_preview_missing_files
        repair_preview_checksum_updates
        repair_preview_orphan_removal
        return 0
    fi

    # Get current roster info
    local roster_commit roster_ref roster_path
    roster_commit=$(get_roster_commit)
    roster_ref=$(get_roster_ref)
    roster_path="$ROSTER_HOME"

    # Preserve old roster info if current roster seems different
    if [[ -n "$old_roster_path" && "$old_roster_path" != "$roster_path" ]]; then
        log_warning "Roster path changed: $old_roster_path -> $roster_path"
    fi

    # Create new manifest
    local manifest
    manifest=$(create_manifest "$roster_path" "$roster_commit" "$roster_ref")

    # 1. Fix missing files by copying from roster
    local item local_file roster_file checksum
    while IFS= read -r item; do
        [[ -z "$item" ]] && continue

        local_file=".claude/$item"
        roster_file="$ROSTER_HOME/.claude/$item"

        if [[ ! -f "$local_file" ]]; then
            # File missing - try to restore from roster
            if [[ -f "$roster_file" ]]; then
                log "Restoring: $item"
                mkdir -p "$(dirname "$local_file")"
                cp "$roster_file" "$local_file"
                repaired_count=$((repaired_count + 1))
            else
                log_warning "Cannot restore: $item (not in roster)"
                unrepairable=$((unrepairable + 1))
            fi
        fi

        # Add to manifest if file exists now
        if [[ -f "$local_file" ]]; then
            checksum=$(compute_checksum "$local_file")
            manifest=$(add_managed_file "$manifest" ".claude/$item" "copy-replace" "$checksum")
            log_debug "Added: $item"
        fi
    done < <(get_copy_replace_items)

    # 2. Process merge items
    local line strategy
    while IFS= read -r line; do
        [[ -z "$line" ]] && continue

        item="${line%%:*}"
        strategy="${line#*:}"
        local_file=".claude/$item"
        roster_file="$ROSTER_HOME/.claude/$item"

        if [[ ! -f "$local_file" ]]; then
            # File missing - try to restore from roster
            if [[ -f "$roster_file" ]]; then
                log "Restoring: $item"
                mkdir -p "$(dirname "$local_file")"
                cp "$roster_file" "$local_file"
                repaired_count=$((repaired_count + 1))
            else
                log_warning "Cannot restore: $item (not in roster)"
                unrepairable=$((unrepairable + 1))
            fi
        fi

        # Add to manifest if file exists now
        if [[ -f "$local_file" ]]; then
            checksum=$(compute_checksum "$local_file")
            manifest=$(add_managed_file "$manifest" ".claude/$item" "$strategy" "$checksum")
            log_debug "Added: $item (strategy: $strategy)"
        fi
    done < <(get_merge_items)

    # 3. Handle orphaned entries (files in old manifest but not in roster config)
    if [[ -n "$old_manifest" && "$old_manifest" != "{}" ]]; then
        local orphan_count=0
        while IFS= read -r file_entry; do
            [[ -z "$file_entry" ]] && continue

            local file_path
            file_path=$(echo "$file_entry" | jq -r '.path')
            local filename="${file_path#.claude/}"

            # Check if this file is still in our managed lists
            if ! is_copy_replace "$filename" && ! get_merge_strategy "$filename" >/dev/null 2>&1; then
                if [[ -f "$file_path" ]]; then
                    if [[ "$FLAG_FORCE" == "1" ]]; then
                        log "Removing orphan: $file_path"
                        local orphan_backup="${SYNC_ORPHAN_BACKUP_DIR:-.claude/.cem/orphan-backup}"
                        mkdir -p "$orphan_backup"
                        mv "$file_path" "$orphan_backup/$(basename "$file_path").$(date +%Y%m%d-%H%M%S)"
                        repaired_count=$((repaired_count + 1))
                    else
                        log_warning "Orphan found: $file_path (use --force to remove)"
                        orphan_count=$((orphan_count + 1))
                    fi
                fi
            fi
        done < <(echo "$old_manifest" | jq -c '.managed_files[]?' 2>/dev/null)

        if [[ $orphan_count -gt 0 && "$FLAG_FORCE" != "1" ]]; then
            log_warning "$orphan_count orphaned file(s) found - use --force to remove"
        fi
    fi

    # 4. Migrate manifest if old schema
    # (This is handled by creating a fresh v3 manifest)

    # 5. Add repair metadata
    local timestamp
    timestamp=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
    manifest=$(echo "$manifest" | jq \
        --arg t "$timestamp" \
        --arg from "${old_roster_path:-none}" '
        .repaired_at = $t |
        .repair_metadata = {
            repaired_at: $t,
            previous_roster_path: $from
        }')

    # 6. Preserve team info if present
    if [[ -f ".claude/ACTIVE_TEAM" ]]; then
        local team_name
        team_name=$(cat ".claude/ACTIVE_TEAM")
        manifest=$(update_manifest_team "$manifest" "$team_name" "")
        log "Team preserved: $team_name"
    fi

    # Write manifest
    mkdir -p "$(dirname "$manifest_file")"
    write_manifest "$manifest"

    # Summary
    local file_count
    file_count=$(echo "$manifest" | jq '.managed_files | length')

    echo ""
    log "Repair Summary:"
    log "  Managed files: $file_count"
    log "  Files restored: $repaired_count"
    log "  Unrepairable: $unrepairable"

    if [[ $unrepairable -gt 0 ]]; then
        log_warning "Some files could not be restored"
        return "$EXIT_SYNC_INVALID_MANIFEST"
    fi

    log_success "Manifest repaired"
    return 0
}

# Helper: Preview missing files that would be restored
repair_preview_missing_files() {
    local item local_file roster_file

    log "  Missing files to restore:"
    local count=0

    while IFS= read -r item; do
        [[ -z "$item" ]] && continue
        local_file=".claude/$item"
        roster_file="$ROSTER_HOME/.claude/$item"

        if [[ ! -f "$local_file" && -f "$roster_file" ]]; then
            log "    + $item (from roster)"
            count=$((count + 1))
        fi
    done < <(get_copy_replace_items)

    local line
    while IFS= read -r line; do
        [[ -z "$line" ]] && continue
        item="${line%%:*}"
        local_file=".claude/$item"
        roster_file="$ROSTER_HOME/.claude/$item"

        if [[ ! -f "$local_file" && -f "$roster_file" ]]; then
            log "    + $item (from roster)"
            count=$((count + 1))
        fi
    done < <(get_merge_items)

    if [[ $count -eq 0 ]]; then
        log "    (none)"
    fi
}

# Helper: Preview checksum updates
repair_preview_checksum_updates() {
    log "  Checksums to update:"
    log "    (all existing files will have checksums recalculated)"
}

# Helper: Preview orphan removal
repair_preview_orphan_removal() {
    local manifest_file="${SYNC_MANIFEST_FILE:-.claude/.cem/manifest.json}"

    if [[ ! -f "$manifest_file" ]]; then
        log "  Orphans to remove:"
        log "    (no existing manifest)"
        return
    fi

    local old_manifest
    old_manifest=$(cat "$manifest_file" 2>/dev/null || echo "{}")

    if ! echo "$old_manifest" | jq -e . >/dev/null 2>&1; then
        log "  Orphans to remove:"
        log "    (manifest is invalid)"
        return
    fi

    log "  Orphans to remove (with --force):"
    local count=0

    while IFS= read -r file_entry; do
        [[ -z "$file_entry" ]] && continue

        local file_path
        file_path=$(echo "$file_entry" | jq -r '.path')
        local filename="${file_path#.claude/}"

        if ! is_copy_replace "$filename" && ! get_merge_strategy "$filename" >/dev/null 2>&1; then
            if [[ -f "$file_path" ]]; then
                log "    - $file_path"
                count=$((count + 1))
            fi
        fi
    done < <(echo "$old_manifest" | jq -c '.managed_files[]?' 2>/dev/null)

    if [[ $count -eq 0 ]]; then
        log "    (none)"
    fi
}

# ============================================================================
# Command: status
# ============================================================================

cmd_status() {
    local manifest_file="${SYNC_MANIFEST_FILE:-.claude/.cem/manifest.json}"

    echo "roster-sync status"
    echo "=================="
    echo ""

    # Check initialization
    if [[ ! -f "$manifest_file" ]]; then
        echo "Status: NOT INITIALIZED"
        echo ""
        echo "Run: roster-sync init"
        return 0
    fi

    # Read manifest
    local manifest
    manifest=$(read_manifest) || {
        echo "Status: MANIFEST ERROR"
        return 1
    }

    local schema_version roster_path roster_commit last_sync file_count
    schema_version=$(echo "$manifest" | jq -r '.schema_version // 1')
    roster_path=$(echo "$manifest" | jq -r '.roster.path // "unknown"')
    roster_commit=$(echo "$manifest" | jq -r '.roster.commit // "unknown"')
    last_sync=$(echo "$manifest" | jq -r '.roster.last_sync // "never"')
    file_count=$(echo "$manifest" | jq '.managed_files | length')

    echo "Schema Version: $schema_version"
    echo "Roster Path:    $roster_path"
    echo "Last Sync:      $last_sync"
    echo "Managed Files:  $file_count"
    echo ""

    # Check for updates
    local current_commit
    current_commit=$(get_roster_commit)

    if [[ -n "$current_commit" && "$current_commit" != "$roster_commit" ]]; then
        echo -e "${YELLOW}Updates Available!${NC}"
        if [[ -d "$roster_path/.git" ]]; then
            local ahead_count
            ahead_count=$(git -C "$roster_path" rev-list --count "$roster_commit".."$current_commit" 2>/dev/null || echo "?")
            echo "  Commits behind: $ahead_count"
        fi
    else
        echo -e "${GREEN}Up to date${NC}"
    fi
    echo ""

    # Active team status
    if [[ -f ".claude/ACTIVE_TEAM" ]]; then
        local team_name
        team_name=$(cat ".claude/ACTIVE_TEAM")
        echo "Active Team: $team_name"

        if is_team_stale; then
            echo -e "  ${YELLOW}Team may need refresh${NC}"
        fi
    fi

    # Check for conflicts
    local backup_count
    backup_count=$(count_conflict_backups)
    if [[ "$backup_count" -gt 0 ]]; then
        echo ""
        echo -e "${YELLOW}Unresolved Conflicts: $backup_count${NC}"
    fi
}

# ============================================================================
# Command: diff
# ============================================================================

cmd_diff() {
    local specific_file="${1:-}"

    if [[ -n "$specific_file" ]]; then
        # Diff specific file
        local roster_file=".claude/$specific_file"
        local local_file=".claude/$specific_file"

        if [[ ! -f "$ROSTER_HOME/$roster_file" ]]; then
            log_error "File not found in roster: $specific_file"
            return 1
        fi

        if [[ ! -f "$local_file" ]]; then
            log_error "File not found locally: $specific_file"
            return 1
        fi

        diff -u "$ROSTER_HOME/$roster_file" "$local_file" || true
    else
        # Diff all managed files
        log "Comparing managed files with roster..."
        echo ""

        local item roster_file local_file
        while IFS= read -r item; do
            [[ -z "$item" ]] && continue

            roster_file="$ROSTER_HOME/.claude/$item"
            local_file=".claude/$item"

            if [[ ! -f "$roster_file" ]]; then
                continue
            fi

            if [[ ! -f "$local_file" ]]; then
                echo "NEW (not local): $item"
                continue
            fi

            if ! diff -q "$roster_file" "$local_file" >/dev/null 2>&1; then
                echo "DIFFERENT: $item"
            fi
        done < <(get_all_managed_files)
    fi
}

# ============================================================================
# Main
# ============================================================================

main() {
    # Parse global flags first
    parse_global_flags "$@"
    set -- "${REMAINING_ARGS[@]}"

    # Get command
    local command="${1:-}"

    # Handle help/version before loading library
    case "$command" in
        -h|--help|help)
            show_help
            exit 0
            ;;
        -v|--version|version)
            show_version
            exit 0
            ;;
    esac

    # Check dependencies
    check_dependencies

    # Load sync library
    load_sync_library

    # Detect checksum tool early
    detect_checksum_tool

    # Dispatch command
    case "$command" in
        init)
            shift
            cmd_init "$@"
            ;;
        sync)
            shift
            cmd_sync "$@"
            ;;
        validate)
            shift
            cmd_validate "$@"
            ;;
        repair)
            shift
            cmd_repair "$@"
            ;;
        status)
            shift
            cmd_status "$@"
            ;;
        diff)
            shift
            cmd_diff "$@"
            ;;
        "")
            log_error "No command specified"
            echo ""
            show_help
            exit 1
            ;;
        *)
            log_error "Unknown command: $command"
            echo ""
            show_help
            exit 1
            ;;
    esac
}

main "$@"
