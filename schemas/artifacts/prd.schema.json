{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://roster.local/schemas/artifacts/prd.schema.json",
  "title": "PRD Schema",
  "description": "Schema for Product Requirements Document YAML frontmatter",
  "type": "object",

  "required": [
    "artifact_id",
    "title",
    "status",
    "created_at",
    "author"
  ],

  "properties": {
    "artifact_id": {
      "$ref": "common.schema.json#/$defs/artifact_id_prd"
    },
    "prd_id": {
      "$ref": "common.schema.json#/$defs/artifact_id_prd",
      "description": "Alias for artifact_id (deprecated, use artifact_id)"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "PRD title"
    },
    "status": {
      "$ref": "common.schema.json#/$defs/workflow_status_enum"
    },
    "created_at": {
      "$ref": "common.schema.json#/$defs/iso8601_timestamp"
    },
    "updated_at": {
      "$ref": "common.schema.json#/$defs/iso8601_timestamp"
    },
    "author": {
      "type": "string",
      "minLength": 1,
      "description": "Document author"
    },
    "complexity": {
      "$ref": "common.schema.json#/$defs/complexity_enum"
    },
    "stakeholders": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of stakeholders"
    },
    "success_criteria": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "description": "List of success criteria"
    },
    "related_prds": {
      "type": "array",
      "items": { "$ref": "common.schema.json#/$defs/artifact_id_prd" },
      "description": "Related PRD references"
    },
    "schema_version": {
      "$ref": "common.schema.json#/$defs/schema_version",
      "default": "1.0"
    }
  },

  "additionalProperties": true,

  "examples": [
    {
      "artifact_id": "PRD-artifact-schema-standardization",
      "title": "Artifact Schema Standardization",
      "status": "approved",
      "created_at": "2025-12-29T20:00:00Z",
      "author": "requirements-analyst",
      "complexity": "SYSTEM",
      "success_criteria": [
        "All artifact types have JSON Schema definitions",
        "Validation hook rejects malformed artifacts",
        "At least one generator updated for compliance"
      ],
      "schema_version": "1.0"
    }
  ]
}
