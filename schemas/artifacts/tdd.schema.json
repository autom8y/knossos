{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://roster.local/schemas/artifacts/tdd.schema.json",
  "title": "TDD Schema",
  "description": "Schema for Technical Design Document YAML frontmatter",
  "type": "object",

  "required": [
    "artifact_id",
    "title",
    "status",
    "prd_ref"
  ],

  "properties": {
    "artifact_id": {
      "$ref": "common.schema.json#/$defs/artifact_id_tdd"
    },
    "tdd_id": {
      "$ref": "common.schema.json#/$defs/artifact_id_tdd",
      "description": "Alias for artifact_id (deprecated, use artifact_id)"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "TDD title"
    },
    "status": {
      "$ref": "common.schema.json#/$defs/workflow_status_enum"
    },
    "prd_ref": {
      "$ref": "common.schema.json#/$defs/artifact_id_prd",
      "description": "Reference to parent PRD"
    },
    "created_at": {
      "$ref": "common.schema.json#/$defs/iso8601_timestamp"
    },
    "updated_at": {
      "$ref": "common.schema.json#/$defs/iso8601_timestamp"
    },
    "author": {
      "type": "string",
      "minLength": 1,
      "description": "Document author"
    },
    "components": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "responsibility": { "type": "string" },
          "owner": { "type": "string" }
        }
      },
      "description": "Component breakdown"
    },
    "related_tdds": {
      "type": "array",
      "items": { "$ref": "common.schema.json#/$defs/artifact_id_tdd" },
      "description": "Related TDD references"
    },
    "related_adrs": {
      "type": "array",
      "items": { "$ref": "common.schema.json#/$defs/artifact_id_adr" },
      "description": "Related ADR references"
    },
    "schema_version": {
      "$ref": "common.schema.json#/$defs/schema_version",
      "default": "1.0"
    }
  },

  "additionalProperties": true,

  "examples": [
    {
      "artifact_id": "TDD-artifact-schema-registry",
      "title": "Artifact Schema Registry Design",
      "status": "approved",
      "prd_ref": "PRD-artifact-schema-standardization",
      "created_at": "2025-12-29T21:00:00Z",
      "author": "architect",
      "components": [
        { "name": "schema-registry", "responsibility": "Host JSON Schema files", "owner": "roster" },
        { "name": "schema-validator", "responsibility": "Validate frontmatter", "owner": "roster" }
      ],
      "schema_version": "1.0"
    }
  ]
}
