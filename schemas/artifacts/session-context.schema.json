{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://roster.local/schemas/artifacts/session-context.schema.json",
  "title": "SESSION_CONTEXT Schema",
  "description": "Schema for SESSION_CONTEXT.md YAML frontmatter",
  "type": "object",

  "required": [
    "session_id",
    "created_at",
    "initiative",
    "complexity",
    "active_rite",
    "current_phase"
  ],

  "properties": {
    "session_id": {
      "$ref": "common.schema.json#/$defs/session_id"
    },
    "session_state": {
      "$ref": "common.schema.json#/$defs/session_status_enum",
      "description": "Current session state (prefer 'status' for new sessions)"
    },
    "status": {
      "$ref": "common.schema.json#/$defs/session_status_enum",
      "description": "Current session status (canonical field)"
    },
    "created_at": {
      "$ref": "common.schema.json#/$defs/iso8601_timestamp"
    },
    "initiative": {
      "type": "string",
      "minLength": 1,
      "description": "Initiative or feature being worked on"
    },
    "complexity": {
      "$ref": "common.schema.json#/$defs/complexity_enum"
    },
    "active_rite": {
      "$ref": "common.schema.json#/$defs/rite_name"
    },
    "current_phase": {
      "type": "string",
      "minLength": 1,
      "description": "Current workflow phase (e.g., requirements, design, implementation)"
    },
    "completed_at": {
      "$ref": "common.schema.json#/$defs/iso8601_timestamp"
    },
    "parked_at": {
      "$ref": "common.schema.json#/$defs/iso8601_timestamp",
      "description": "Timestamp when session was manually parked"
    },
    "parked_reason": {
      "type": "string",
      "description": "Reason for manual session parking"
    },
    "parked_git_status": {
      "type": "string",
      "description": "Git working tree status at time of manual park (e.g., 'clean', 'uncommitted changes')"
    },
    "auto_parked_at": {
      "$ref": "common.schema.json#/$defs/iso8601_timestamp",
      "description": "Timestamp when session was automatically parked"
    },
    "auto_parked_reason": {
      "type": "string",
      "description": "Reason for automatic session parking"
    },
    "resumed_at": {
      "$ref": "common.schema.json#/$defs/iso8601_timestamp"
    },
    "schema_version": {
      "$ref": "common.schema.json#/$defs/schema_version",
      "default": "1.0"
    },
    "moirai_agent_id": {
      "type": "string",
      "pattern": "^[a-f0-9]{8}$",
      "description": "Unique identifier for Moirai agent instance, persisted across context compaction. Generated on first mutation, used to verify continuity."
    }
  },

  "additionalProperties": true,

  "examples": [
    {
      "session_id": "session-20251229-181045-b06b3bb8",
      "status": "ACTIVE",
      "created_at": "2025-12-29T23:10:45Z",
      "initiative": "Artifact Schema Standardization",
      "complexity": "SYSTEM",
      "active_rite": "ecosystem",
      "current_phase": "design",
      "schema_version": "1.0"
    }
  ]
}
