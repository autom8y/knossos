#!/bin/bash
# pre-commit hook for orchestrator.yaml/md synchronization
#
# Purpose: Catch orchestrator drift before it reaches CI
# This hook automatically:
# 1. Validates orchestrator.yaml against schema
# 2. Regenerates orchestrator.md from YAML if YAML changed
# 3. Warns if orchestrator.md changed without YAML change
# 4. Prevents commits with drift (unless explicitly overridden)
#
# Install: cp .githooks/pre-commit-orchestrator .git/hooks/pre-commit
# Bypass: git commit --no-verify
#
# Exit codes:
#   0 = All checks passed
#   1 = Drift detected, commit blocked (unless --no-verify)
#   2 = Schema validation failed

set -euo pipefail

# Configuration
readonly SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
readonly REPO_ROOT="$(git rev-parse --show-toplevel)"
readonly GENERATOR="$REPO_ROOT/templates/orchestrator-generate.sh"
readonly VALIDATOR="$REPO_ROOT/templates/validate-orchestrator.sh"

# Colors for output
readonly RED='\033[0;31m'
readonly GREEN='\033[0;32m'
readonly YELLOW='\033[1;33m'
readonly BLUE='\033[0;34m'
readonly NC='\033[0m'

# State tracking
VALIDATION_PASSED=true
CHANGES_MADE=false
YAML_CHANGED_FILES=()
MD_CHANGED_FILES=()
TEAMS_TO_REGENERATE=()

# ============================================================================
# Logging
# ============================================================================

log_info() { echo -e "${BLUE}INFO${NC}: $*"; }
log_ok() { echo -e "${GREEN}OK${NC}: $*"; }
log_warn() { echo -e "${YELLOW}WARN${NC}: $*" >&2; }
log_error() { echo -e "${RED}ERROR${NC}: $*" >&2; }

# ============================================================================
# Change Detection
# ============================================================================

detect_orchestrator_changes() {
    # Find all changed orchestrator files in staging area
    local changed_yaml changed_md

    # Changed YAML files
    changed_yaml=$(git diff --cached --name-only --diff-filter=ACMR | grep 'teams/.*/orchestrator\.yaml' || true)
    # Changed MD files
    changed_md=$(git diff --cached --name-only --diff-filter=ACMR | grep 'teams/.*/agents/orchestrator\.md' || true)

    # Store in arrays for processing
    if [[ -n "$changed_yaml" ]]; then
        while read -r file; do
            [[ -n "$file" ]] && YAML_CHANGED_FILES+=("$file")
        done <<<"$changed_yaml"
    fi

    if [[ -n "$changed_md" ]]; then
        while read -r file; do
            [[ -n "$file" ]] && MD_CHANGED_FILES+=("$file")
        done <<<"$changed_md"
    fi
}

extract_team_name() {
    local file="$1"
    # Extract team name from path like "teams/rnd-pack/orchestrator.yaml"
    echo "$file" | sed -E 's|teams/([^/]+)/.*|\1|'
}

# ============================================================================
# Validation
# ============================================================================

validate_yaml_schema() {
    local yaml_file="$1"

    log_info "Validating YAML: $yaml_file"

    if [[ ! -f "$REPO_ROOT/$yaml_file" ]]; then
        log_error "File not found: $yaml_file"
        VALIDATION_PASSED=false
        return 1
    fi

    # Run generator in validate-only mode
    if ! "$GENERATOR" "$(extract_team_name "$yaml_file")" --validate-only >/dev/null 2>&1; then
        log_error "Schema validation failed: $yaml_file"
        VALIDATION_PASSED=false
        return 1
    fi

    log_ok "YAML validated: $yaml_file"
    return 0
}

regenerate_orchestrator() {
    local team="$1"
    local md_file="teams/$team/agents/orchestrator.md"

    log_info "Regenerating orchestrator.md for: $team"

    # Generate new version to temporary file
    local temp_file
    temp_file=$(mktemp)
    trap "rm -f $temp_file" RETURN

    # Run generator
    if ! "$GENERATOR" "$team" --force >/dev/null 2>&1; then
        log_error "Failed to generate orchestrator.md for: $team"
        VALIDATION_PASSED=false
        return 1
    fi

    # Check if file changed
    if [[ -f "$REPO_ROOT/$md_file" ]]; then
        if ! diff -q "$REPO_ROOT/$md_file" <("$GENERATOR" "$team" --dry-run 2>/dev/null | tail -n +4 | head -n -2) >/dev/null 2>&1; then
            log_info "Changes detected in regenerated $md_file, staging update"
            git add "$md_file"
            CHANGES_MADE=true
        fi
    fi

    log_ok "Regenerated: $md_file"
    return 0
}

# ============================================================================
# Drift Detection
# ============================================================================

check_md_without_yaml() {
    local md_file="$1"
    local team=$(extract_team_name "$md_file")
    local yaml_file="teams/$team/orchestrator.yaml"

    # Check if corresponding YAML file exists and was also changed
    local yaml_in_changes=false
    for yaml in "${YAML_CHANGED_FILES[@]}"; do
        if [[ "$yaml" == "$yaml_file" ]]; then
            yaml_in_changes=true
            break
        fi
    done

    if [[ "$yaml_in_changes" == false ]]; then
        log_warn "orchestrator.md changed without orchestrator.yaml: $md_file"
        log_warn "This breaks the generation contract. Recommended: update orchestrator.yaml instead."
        log_info ""
        log_info "To fix:"
        log_info "  1. Run: $GENERATOR $team --force"
        log_info "  2. Review changes: git diff $md_file"
        log_info "  3. Stage: git add $md_file"
        log_info "  4. Commit: git commit --amend"
        log_info ""
        log_info "To bypass this check (not recommended):"
        log_info "  git commit --no-verify"
        return 1
    fi

    return 0
}

# ============================================================================
# Main Hook Logic
# ============================================================================

main() {
    # Only run if orchestrator files are in the commit
    detect_orchestrator_changes

    if [[ ${#YAML_CHANGED_FILES[@]} -eq 0 ]] && [[ ${#MD_CHANGED_FILES[@]} -eq 0 ]]; then
        # No orchestrator files changed
        exit 0
    fi

    log_info "Found ${#YAML_CHANGED_FILES[@]} YAML file(s) and ${#MD_CHANGED_FILES[@]} MD file(s) to validate"
    echo ""

    # Check dependencies
    if [[ ! -f "$GENERATOR" ]] || [[ ! -f "$VALIDATOR" ]]; then
        log_warn "Generator or validator not found, skipping orchestrator validation"
        exit 0
    fi

    # Validate all YAML files
    for yaml_file in "${YAML_CHANGED_FILES[@]}"; do
        local team=$(extract_team_name "$yaml_file")
        validate_yaml_schema "$yaml_file" || continue
        TEAMS_TO_REGENERATE+=("$team")
    done

    # Regenerate orchestrator.md from YAML if YAML changed
    for team in "${TEAMS_TO_REGENERATE[@]}"; do
        regenerate_orchestrator "$team" || true
    done

    # Check for MD without YAML (drift detection)
    for md_file in "${MD_CHANGED_FILES[@]}"; do
        check_md_without_yaml "$md_file" || VALIDATION_PASSED=false
    done

    echo ""

    # Final report
    if [[ "$VALIDATION_PASSED" == true ]]; then
        log_ok "Pre-commit validation passed"
        [[ "$CHANGES_MADE" == true ]] && log_info "Regenerated orchestrators have been staged"
        exit 0
    else
        log_error "Pre-commit validation failed"
        log_error "Please fix the issues above and try again"
        log_info "Or use 'git commit --no-verify' to bypass (not recommended)"
        exit 1
    fi
}

main "$@"
