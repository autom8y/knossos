{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "embed:///schemas/prd.schema.json",
  "title": "PRD Schema",
  "description": "Schema for Product Requirements Document YAML frontmatter",
  "type": "object",

  "required": [
    "artifact_id",
    "title",
    "status",
    "created_at",
    "author"
  ],

  "properties": {
    "artifact_id": {
      "$ref": "embed:///schemas/common.schema.json#/$defs/artifact_id_prd"
    },
    "prd_id": {
      "$ref": "embed:///schemas/common.schema.json#/$defs/artifact_id_prd",
      "description": "Alias for artifact_id (deprecated, use artifact_id)"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "PRD title"
    },
    "status": {
      "$ref": "embed:///schemas/common.schema.json#/$defs/workflow_status_enum"
    },
    "created_at": {
      "$ref": "embed:///schemas/common.schema.json#/$defs/iso8601_timestamp"
    },
    "updated_at": {
      "$ref": "embed:///schemas/common.schema.json#/$defs/iso8601_timestamp"
    },
    "author": {
      "type": "string",
      "minLength": 1,
      "description": "Document author"
    },
    "complexity": {
      "$ref": "embed:///schemas/common.schema.json#/$defs/complexity_enum"
    },
    "stakeholders": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of stakeholders"
    },
    "success_criteria": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "description": "List of success criteria"
    },
    "related_prds": {
      "type": "array",
      "items": { "$ref": "embed:///schemas/common.schema.json#/$defs/artifact_id_prd" },
      "description": "Related PRD references"
    },
    "schema_version": {
      "$ref": "embed:///schemas/common.schema.json#/$defs/schema_version",
      "default": "1.0"
    }
  },

  "additionalProperties": true
}
