# Compiled binaries
ari

# Knossos-managed runtime directory
# Canonical sources: knossos (ecosystem), rites/*/ (team definitions)
# .claude/ is regenerated via knossos-sync and rite swap
.claude/

# Ephemeral working artifacts (pre-permanent scratch layer)
# Canonical convention defined in rites/shared/mena/ephemeral-artifacts/
.wip/

# Persistent codebase knowledge (generated by /know, consumed by agents)
.know/

# Agent memory (persistent per-agent learning state, not committed)
.claude/agent-memory/
.claude/agent-memory-local/
