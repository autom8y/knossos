# Compiled binaries
ari

# Knossos-managed runtime directory
# Canonical sources: knossos (ecosystem), rites/*/ (team definitions)
# .claude/ is regenerated via knossos-sync and rite swap
#
# WORKTREE NOTE: .claude/, .sos/, and .knossos/ are gitignored and absent in
# linked worktrees created via `git worktree add` or CC EnterWorktree. Run
# `ari sync` once in the worktree to scaffold all required framework directories
# and inherit the active rite from the main worktree (see ADR-0029).
.claude/

# Session state and lifecycle (sessions, locks, cc-map, archive, wip)
.sos/

# Legacy ephemeral workspace (migrated to .sos/wip/)
.wip/

# Persistent codebase knowledge (generated by /know, consumed by agents)
.know/

# Work product artifacts (decisions, specs, reviews, spikes)
.ledge/

# Agent memory (persistent per-agent learning state, not committed)
.claude/agent-memory/
.claude/agent-memory-local/

# Knossos internal state within .knossos/ (ephemeral, not tracked)
.knossos/sync/
.knossos/backups/
.knossos/worktrees/
.knossos/.el-cheapo-active
.knossos/.worktree-meta.json
.knossos/KNOSSOS_MANIFEST.yaml
.knossos/INVOCATION_STATE.yaml
