#!/bin/bash
# rapid-session-test - Single-command runner for Session FSM test suite
#
# Usage:
#   bin/rapid-session-test              # Run all tests
#   bin/rapid-session-test --quick      # Run only state transition tests
#   bin/rapid-session-test --verbose    # Verbose output
#   bin/rapid-session-test --filter "fsm_001"  # Run specific test
#
# Exit codes:
#   0 - All tests passed
#   1 - One or more tests failed
#   2 - BATS not installed or test files not found
#
# Reference: TDD-session-state-machine.md (Test Strategy section)

set -euo pipefail

# =============================================================================
# Configuration
# =============================================================================

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
TEST_DIR="$PROJECT_ROOT/tests/session-fsm"

# Colors for output (if terminal supports them)
if [[ -t 1 ]] && command -v tput >/dev/null 2>&1; then
    RED=$(tput setaf 1)
    GREEN=$(tput setaf 2)
    YELLOW=$(tput setaf 3)
    BLUE=$(tput setaf 4)
    BOLD=$(tput bold)
    RESET=$(tput sgr0)
else
    RED=""
    GREEN=""
    YELLOW=""
    BLUE=""
    BOLD=""
    RESET=""
fi

# =============================================================================
# Functions
# =============================================================================

print_header() {
    echo ""
    echo "${BOLD}${BLUE}======================================${RESET}"
    echo "${BOLD}${BLUE}  Session FSM Test Suite${RESET}"
    echo "${BOLD}${BLUE}======================================${RESET}"
    echo ""
}

print_usage() {
    cat <<EOF
Usage: $(basename "$0") [OPTIONS]

Run the Session FSM test suite.

Options:
  --quick, -q       Run only state transition tests (fastest)
  --verbose, -v     Show verbose test output
  --filter PATTERN  Run only tests matching pattern
  --list, -l        List available tests without running
  --help, -h        Show this help message

Test Files:
  test_state_transitions.bats  - FSM state transition tests (TLA+ invariants)
  test_locking.bats            - Advisory lock tests (concurrency)
  test_migration.bats          - v1 to v2 schema migration tests

Examples:
  $(basename "$0")                     # Run all tests
  $(basename "$0") --quick             # Run state transition tests only
  $(basename "$0") --filter "fsm_"     # Run FSM-numbered tests
  $(basename "$0") --filter "migrate"  # Run migration tests

Exit Codes:
  0  All tests passed
  1  One or more tests failed
  2  Setup error (BATS not found, etc.)

EOF
}

check_bats() {
    if ! command -v bats >/dev/null 2>&1; then
        echo "${RED}Error: BATS not installed${RESET}" >&2
        echo "" >&2
        echo "Install BATS with one of:" >&2
        echo "  brew install bats-core        # macOS" >&2
        echo "  apt-get install bats          # Debian/Ubuntu" >&2
        echo "  npm install -g bats           # via npm" >&2
        return 2
    fi
    return 0
}

check_test_files() {
    local missing=0

    if [[ ! -d "$TEST_DIR" ]]; then
        echo "${RED}Error: Test directory not found: $TEST_DIR${RESET}" >&2
        return 2
    fi

    local test_files=(
        "test_state_transitions.bats"
        "test_locking.bats"
        "test_migration.bats"
        "test_helpers.bash"
    )

    for file in "${test_files[@]}"; do
        if [[ ! -f "$TEST_DIR/$file" ]]; then
            echo "${RED}Error: Missing test file: $TEST_DIR/$file${RESET}" >&2
            missing=1
        fi
    done

    if [[ $missing -eq 1 ]]; then
        return 2
    fi
    return 0
}

list_tests() {
    echo "${BOLD}Available Tests:${RESET}"
    echo ""

    for test_file in "$TEST_DIR"/*.bats; do
        [[ -f "$test_file" ]] || continue

        local filename
        filename=$(basename "$test_file")
        echo "${YELLOW}$filename:${RESET}"

        # Extract test names from file
        grep -E "^@test\s+" "$test_file" | sed 's/@test "\([^"]*\)".*/  - \1/' || true
        echo ""
    done
}

run_tests() {
    local quick_mode=false
    local verbose_mode=false
    local filter=""
    local bats_args=()

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --quick|-q)
                quick_mode=true
                shift
                ;;
            --verbose|-v)
                verbose_mode=true
                shift
                ;;
            --filter)
                filter="$2"
                shift 2
                ;;
            --list|-l)
                list_tests
                return 0
                ;;
            --help|-h)
                print_usage
                return 0
                ;;
            *)
                echo "${RED}Unknown option: $1${RESET}" >&2
                print_usage >&2
                return 2
                ;;
        esac
    done

    # Check prerequisites
    check_bats || return $?
    check_test_files || return $?

    print_header

    # Build BATS arguments
    if [[ "$verbose_mode" == "true" ]]; then
        bats_args+=("--verbose-run")
    fi

    # Determine which test files to run
    local test_files=()
    if [[ "$quick_mode" == "true" ]]; then
        echo "${YELLOW}Quick mode: Running state transitions only${RESET}"
        echo ""
        test_files=("$TEST_DIR/test_state_transitions.bats")
    else
        # Run all tests
        test_files=(
            "$TEST_DIR/test_state_transitions.bats"
            "$TEST_DIR/test_locking.bats"
            "$TEST_DIR/test_migration.bats"
        )
    fi

    # Apply filter if specified
    if [[ -n "$filter" ]]; then
        echo "${YELLOW}Filter: $filter${RESET}"
        echo ""
        bats_args+=("--filter" "$filter")
    fi

    # Show test file summary
    echo "${BOLD}Running tests:${RESET}"
    for file in "${test_files[@]}"; do
        echo "  - $(basename "$file")"
    done
    echo ""

    # Record start time
    local start_time
    start_time=$(date +%s)

    # Run BATS
    local exit_code=0
    if [[ ${#bats_args[@]} -gt 0 ]]; then
        if ! bats "${bats_args[@]}" "${test_files[@]}"; then
            exit_code=1
        fi
    else
        if ! bats "${test_files[@]}"; then
            exit_code=1
        fi
    fi

    # Calculate duration
    local end_time
    end_time=$(date +%s)
    local duration=$((end_time - start_time))

    # Print summary
    echo ""
    echo "${BOLD}======================================${RESET}"
    if [[ $exit_code -eq 0 ]]; then
        echo "${GREEN}${BOLD}  All tests passed!${RESET}"
    else
        echo "${RED}${BOLD}  Some tests failed${RESET}"
    fi
    echo "${BOLD}  Duration: ${duration}s${RESET}"
    echo "${BOLD}======================================${RESET}"
    echo ""

    return $exit_code
}

# =============================================================================
# CI Integration Helpers
# =============================================================================

# Output JUnit XML for CI systems (called with --junit)
run_junit() {
    check_bats || return $?
    check_test_files || return $?

    local test_files=(
        "$TEST_DIR/test_state_transitions.bats"
        "$TEST_DIR/test_locking.bats"
        "$TEST_DIR/test_migration.bats"
    )

    # BATS can output TAP format, which can be converted to JUnit
    # For now, just run with --tap format
    bats --tap "${test_files[@]}"
}

# =============================================================================
# Main
# =============================================================================

main() {
    # Handle special modes
    case "${1:-}" in
        --junit)
            run_junit
            ;;
        *)
            run_tests "$@"
            ;;
    esac
}

main "$@"
