{
  "family": "clew",
  "requiresCompatibilities": ["FARGATE"],
  "networkMode": "awsvpc",
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::${AWS_ACCOUNT_ID}:role/clew-ecs-execution",
  "taskRoleArn": "arn:aws:iam::${AWS_ACCOUNT_ID}:role/clew-ecs-task",
  "containerDefinitions": [
    {
      "name": "clew",
      "image": "${ECR_REGISTRY}/clew:${IMAGE_TAG}",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8080,
          "hostPort": 8080,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "PORT", "value": "8080" },
        { "name": "LOG_LEVEL", "value": "INFO" },
        { "name": "MAX_CONCURRENT", "value": "10" },
        { "name": "OTEL_EXPORTER_OTLP_ENDPOINT", "value": "${OTEL_ENDPOINT}" },
        { "name": "OTEL_SERVICE_NAME", "value": "clew" },
        { "name": "KNOSSOS_ORG", "value": "autom8y" }
      ],
      "secrets": [
        {
          "name": "SLACK_SIGNING_SECRET",
          "valueFrom": "arn:aws:secretsmanager:${AWS_REGION}:${AWS_ACCOUNT_ID}:secret:clew/slack-signing-secret"
        },
        {
          "name": "SLACK_BOT_TOKEN",
          "valueFrom": "arn:aws:secretsmanager:${AWS_REGION}:${AWS_ACCOUNT_ID}:secret:clew/slack-bot-token"
        },
        {
          "name": "ANTHROPIC_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:${AWS_REGION}:${AWS_ACCOUNT_ID}:secret:clew/anthropic-api-key"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/clew",
          "awslogs-region": "${AWS_REGION}",
          "awslogs-stream-prefix": "clew"
        }
      },
      "stopTimeout": 30
    }
  ]
}
