{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Rite Manifest",
  "description": "Configuration for a rite defining agents and workflows",
  "type": "object",
  "required": ["version", "name", "workflow", "agents"],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+$",
      "description": "Rite manifest schema version"
    },
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "description": "Rite name (lowercase, alphanumeric with hyphens)"
    },
    "description": {
      "type": "string",
      "description": "Rite description"
    },
    "workflow": {
      "type": "object",
      "required": ["type", "entry_point"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["sequential", "parallel", "hybrid"],
          "description": "Workflow execution type"
        },
        "entry_point": {
          "type": "string",
          "description": "Initial agent in workflow"
        }
      }
    },
    "agents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "file"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Agent name"
          },
          "file": {
            "type": "string",
            "description": "Path to agent definition file"
          },
          "role": {
            "type": "string",
            "description": "Agent role description"
          },
          "produces": {
            "type": "string",
            "description": "What the agent produces"
          }
        }
      },
      "description": "List of agents in this rite"
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Skills available to agents"
    },
    "hooks": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Hooks to execute during workflow"
    }
  }
}
